# =============================================================================
# ADES — Variables de entorno
# Copiar a .env y llenar valores reales. NUNCA commitear .env
# =============================================================================

# --- PostgreSQL ---
POSTGRES_DB=ades
POSTGRES_USER=ades_admin
POSTGRES_PASSWORD=cambia_esto_en_produccion

# Base de datos separada para Authentik
AUTHENTIK_DB=authentik
AUTHENTIK_DB_USER=authentik
AUTHENTIK_DB_PASS=cambia_esto_en_produccion

# --- Valkey ---
VALKEY_PASSWORD=cambia_esto_en_produccion

# --- MinIO ---
MINIO_ROOT_USER=ades_minio
MINIO_ROOT_PASSWORD=cambia_esto_en_produccion

# --- Authentik ---
# Generar con: openssl rand -hex 32
AUTHENTIK_SECRET_KEY=cambia_esto_en_produccion_openssl_rand_hex_32

# --- Authentik SMTP (Zoho Mail — para reset de contraseña y activación de nuevos usuarios) ---
# Puerto 465 con SSL (recomendado Zoho) — mutuamente excluyente con USE_TLS
# Alternativa: SMTP_PORT=587, SMTP_USE_SSL=false, SMTP_USE_TLS=true
SMTP_HOST=smtp.zoho.com
SMTP_PORT=465
SMTP_USE_SSL=true
SMTP_USE_TLS=false
SMTP_FROM=admin@setag.mx
SMTP_USERNAME=admin@setag.mx
SMTP_PASSWORD=contrasena_zoho_aqui

# --- Authentik Google SSO (Social Source — activar cuando se tengan credenciales) ---
# Crear en: https://console.cloud.google.com → APIs → Credenciales → OAuth 2.0
# URI de redirección: https://auth.ades.setag.mx/source/oauth/callback/google/
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# --- API FastAPI ---
# Generar con: openssl rand -hex 32
API_SECRET_KEY=cambia_esto_en_produccion
ENVIRONMENT=development
LOG_LEVEL=info
ALLOWED_ORIGINS=http://ades.setag.mx,https://ades.setag.mx,http://localhost:4200

# --- OIDC (Authentik como IdP) ---
OIDC_ISSUER=https://ades.setag.mx/auth/application/o/ades/
OIDC_CLIENT_ID=ades-frontend
OIDC_CLIENT_SECRET=cambia_esto_tras_crear_app_en_authentik

# --- Superset ---
SUPERSET_SECRET_KEY=cambia_esto_en_produccion
SUPERSET_OIDC_CLIENT_ID=superset
SUPERSET_OIDC_CLIENT_SECRET=cambia_esto_tras_crear_app_en_authentik

# --- Certbot / Let's Encrypt ---
CERTBOT_DOMAIN=ades.setag.mx
CERTBOT_EMAIL=admin@setag.mx   # reemplazar con correo real para notificaciones

# --- Claude API (Fase 4 — asistente IA) ---
ANTHROPIC_API_KEY=

# --- Frontend Angular ---
# development | production
FRONTEND_BUILD_TARGET=development

# --- Fase 4: ClickHouse / Cube (descomentar cuando se active) ---
# CLICKHOUSE_PASSWORD=cambia_esto_en_produccion
# CUBE_API_SECRET=cambia_esto_en_produccion
