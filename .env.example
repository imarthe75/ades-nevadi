# =============================================================================
# ADES — Variables de entorno
# Copiar a .env y llenar valores reales. NUNCA commitear .env
# =============================================================================

# --- PostgreSQL ---
POSTGRES_DB=ades
POSTGRES_USER=ades_admin
POSTGRES_PASSWORD=cambia_esto_en_produccion

# Base de datos separada para Authentik
AUTHENTIK_DB=authentik
AUTHENTIK_DB_USER=authentik
AUTHENTIK_DB_PASS=cambia_esto_en_produccion

# --- Valkey ---
VALKEY_PASSWORD=cambia_esto_en_produccion

# --- MinIO ---
MINIO_ROOT_USER=ades_minio
MINIO_ROOT_PASSWORD=cambia_esto_en_produccion

# --- Authentik ---
# Generar con: openssl rand -hex 32
AUTHENTIK_SECRET_KEY=cambia_esto_en_produccion_openssl_rand_hex_32

# --- Authentik SMTP (Zoho Mail — para reset de contraseña y activación de nuevos usuarios) ---
# Puerto 465 con SSL (recomendado Zoho) — mutuamente excluyente con USE_TLS
# Alternativa: SMTP_PORT=587, SMTP_USE_SSL=false, SMTP_USE_TLS=true
SMTP_HOST=smtp.zoho.com
SMTP_PORT=465
SMTP_USE_SSL=true
SMTP_USE_TLS=false
SMTP_FROM=admin@setag.mx
SMTP_USERNAME=admin@setag.mx
SMTP_PASSWORD=contrasena_zoho_aqui

# --- Authentik Google SSO (Social Source — activar cuando se tengan credenciales) ---
# Crear en: https://console.cloud.google.com → APIs → Credenciales → OAuth 2.0
# URI de redirección: https://auth.ades.setag.mx/source/oauth/callback/google/
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# --- API FastAPI ---
# Generar con: openssl rand -hex 32
API_SECRET_KEY=cambia_esto_en_produccion
ENVIRONMENT=development
LOG_LEVEL=info
ALLOWED_ORIGINS=http://ades.setag.mx,https://ades.setag.mx,http://localhost:4200

# --- OIDC (Authentik como IdP) ---
OIDC_ISSUER=https://ades.setag.mx/auth/application/o/ades/
OIDC_CLIENT_ID=ades-frontend
OIDC_CLIENT_SECRET=cambia_esto_tras_crear_app_en_authentik

# --- Superset ---
SUPERSET_SECRET_KEY=cambia_esto_en_produccion
SUPERSET_OIDC_CLIENT_ID=superset
SUPERSET_OIDC_CLIENT_SECRET=cambia_esto_tras_crear_app_en_authentik
SUPERSET_OIDC_ISSUER=https://auth.ades.setag.mx/application/o/superset
# Contraseña para el usuario superset_ro (solo lectura a ades_bi) — ver mig 016
SUPERSET_RO_PASSWORD=cambia_esto_en_produccion
# Admin inicial de Superset (usar para init.sh)
SUPERSET_ADMIN_PASSWORD=cambia_esto_en_produccion
SUPERSET_ADMIN_EMAIL=admin@institutonevadi.edu.mx
# UUIDs de dashboards embebidos (llenar tras crear en Superset UI)
SUPERSET_DASHBOARD_INSTITUTO=
SUPERSET_DASHBOARD_PLANTEL=
SUPERSET_DASHBOARD_DOCENTE=
SUPERSET_DASHBOARD_ALUMNO=

# --- Certbot / Let's Encrypt ---
CERTBOT_DOMAIN=ades.setag.mx
CERTBOT_EMAIL=admin@setag.mx   # reemplazar con correo real para notificaciones

# --- Claude API (Fase 4 — asistente IA) ---
ANTHROPIC_API_KEY=

# --- Frontend Angular ---
# development | production
FRONTEND_BUILD_TARGET=development

# --- Carbone (FASE 18 — Generador de reportes) ---
# URL interna: http://ades-carbone:3000
# No se expone al exterior; FastAPI actúa de proxy

# --- Flowise (FASE 17 — AI Chatbot) ---
FLOWISE_USERNAME=admin
FLOWISE_PASSWORD=cambia_esto_en_produccion
FLOWISE_SECRET_KEY=cambia_esto_con_openssl_rand_hex_32
# UUID del chatflow principal (llenar tras configurar en Flowise UI)
FLOWISE_CHATFLOW_ID=
# API key para llamadas internas FastAPI → Flowise
FLOWISE_API_KEY=

# --- ntfy (FASE 20 — Push Notifications) ---
NTFY_BASE_URL=http://notify.ades.setag.mx
# Token admin para publicar en ntfy (generado con: ntfy token add admin)
NTFY_ADMIN_TOKEN=
# Token de lectura para suscripción desde el frontend
NTFY_READ_TOKEN=

# --- Stirling-PDF (FASE 21 — Procesamiento PDF) ---
# URL interna: http://ades-stirling-pdf:8080

# --- Grafana (FASE 22 — Monitoreo) ---
GRAFANA_URL=http://monitor.ades.setag.mx
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=cambia_esto_en_produccion

# --- n8n (FASE 23 — Automatización de flujos) ---
N8N_URL=http://localhost:5678
N8N_WEBHOOK_URL=http://ades-n8n:5678
N8N_USER=admin
N8N_PASSWORD=cambia_esto_en_produccion
# Generar con: openssl rand -hex 24
N8N_ENCRYPTION_KEY=cambia_esto_en_produccion
N8N_DB=n8n
# API key interna para que n8n llame al backend ADES
ADES_INTERNAL_API_KEY=cambia_esto_en_produccion

# --- Centinela-AI Compliance (GitLab local + Gemini) ---
GITLAB_BASE_URL=http://gitlab.local
GITLAB_API_TOKEN=
GITLAB_READ_TOKEN=
GITLAB_WEBHOOK_SECRET=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
COMPLIANCE_TRIVY_CMD=trivy fs --quiet --format json {path}
COMPLIANCE_TRUFFLEHOG_CMD=trufflehog filesystem --json {path}
COMPLIANCE_MEDUSA_CMD=semgrep --config auto --json {path}

# --- Fase 4: ClickHouse / Cube (descomentar cuando se active) ---
# CLICKHOUSE_PASSWORD=cambia_esto_en_produccion
# CUBE_API_SECRET=cambia_esto_en_produccion
