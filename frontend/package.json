{
  "name": "ades-frontend",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:coverage": "ng test --coverage",
    "e2e": "npx playwright test",
    "e2e:ui": "npx playwright test --ui",
    "e2e:headed": "npx playwright test --headed",
    "e2e:report": "npx playwright show-report e2e/reports/html",
    "e2e:auth": "npx playwright test e2e/tests/01-auth.spec.ts",
    "e2e:alumnos": "npx playwright test e2e/tests/02-alumnos.spec.ts",
    "e2e:asistencias": "npx playwright test e2e/tests/03-asistencias.spec.ts",
    "e2e:calificaciones": "npx playwright test e2e/tests/04-calificaciones.spec.ts",
    "e2e:certificados": "npx playwright test e2e/tests/05-certificados.spec.ts",
    "e2e:chaos": "npx playwright test e2e/tests/06-chaos.spec.ts",
    "e2e:fuzz": "npx playwright test e2e/tests/07-fuzz.spec.ts",
    "e2e:api": "npx playwright test e2e/tests/08-api.spec.ts",
    "e2e:smoke": "npx playwright test --grep '@smoke'",
    "lint": "ng lint",
    "generate:api-types": "openapi-typescript http://localhost:8080/v3/api-docs -o src/app/core/models/api-types.generated.ts"
  },
  "private": true,
  "packageManager": "npm@10.9.8",
  "dependencies": {
    "@angular/animations": "^21.2.17",
    "@angular/cdk": "^21.2.14",
    "@angular/common": "^21.2.17",
    "@angular/compiler": "^21.2.17",
    "@angular/core": "^21.2.17",
    "@angular/forms": "^21.2.17",
    "@angular/platform-browser": "^21.2.17",
    "@angular/router": "^21.2.17",
    "@primeng/themes": "^21.0.4",
    "chart.js": "^4.5.1",
    "primeicons": "^7.0.0",
    "primeng": "^21.1.9",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz"
  },
  "devDependencies": {
    "@angular/build": "^21.2.17",
    "@angular/cli": "^21.2.17",
    "@angular/compiler-cli": "^21.2.17",
    "@axe-core/playwright": "^4.11.3",
    "@eslint/js": "^10.0.1",
    "@faker-js/faker": "^10.4.0",
    "@playwright/test": "^1.61.0",
    "@vitest/coverage-v8": "^4.0.8",
    "angular-eslint": "21.4.0",
    "eslint": "^10.3.0",
    "gremlins.js": "^2.2.0",
    "jsdom": "^28.0.0",
    "openapi-typescript": "^7.13.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "typescript-eslint": "8.59.2",
    "vitest": "^4.0.8"
  }
}
