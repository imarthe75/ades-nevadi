{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "cli": {
    "packageManager": "npm",
    "analytics": false,
    "cache": {
      "enabled": true,
      "path": "/tmp/ng-cache",
      "environment": "all"
    }
  },
  "newProjectRoot": "projects",
  "projects": {
    "ades-frontend": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "style": "scss"
        }
      },
      "root": "",
      "sourceRoot": "src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "browser": "src/main.ts",
            "tsConfig": "tsconfig.app.json",
            "inlineStyleLanguage": "scss",
            "assets": [
              {
                "glob": "**/*",
                "input": "public"
              }
            ],
            "styles": [
              "node_modules/primeicons/primeicons.css",
              "src/styles.scss"
            ]
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "600kB",
                  "maximumError": "1.5MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "10kB",
                  "maximumError": "20kB"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "ades-frontend:build:production"
            },
            "development": {
              "buildTarget": "ades-frontend:build:development"
            }
          },
          "defaultConfiguration": "development",
          "options": {
            "allowedHosts": [
              "ades.setag.mx",
              "localhost",
              "127.0.0.1"
            ],
            "port": 4200,
            "host": "0.0.0.0"
          }
        },
        "test": {
          "builder": "@angular/build:unit-test"
        }
      }
    },
    "apex-component-library": {
      "projectType": "library",
      "root": "projects/apex-component-library",
      "sourceRoot": "projects/apex-component-library/src",
      "prefix": "apex",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:ng-packagr",
          "options": {
            "project": "projects/apex-component-library/ng-package.json"
          },
          "configurations": {
            "production": {
              "tsConfig": "projects/apex-component-library/tsconfig.json"
            },
            "development": {
              "tsConfig": "projects/apex-component-library/tsconfig.json"
            }
          },
          "defaultConfiguration": "production"
        }
      }
    }
  }
}