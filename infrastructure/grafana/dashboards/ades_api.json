{
  "__inputs": [],
  "__requires": [],
  "annotations": { "list": [] },
  "description": "ADES FastAPI — Latencia, throughput y errores por endpoint",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "reqps" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "id": 1,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" } },
      "title": "Requests por segundo",
      "type": "timeseries",
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(http_requests_total{job=\"ades-api\"}[5m])",
          "legendFormat": "{{method}} {{handler}} {{status_code}}"
        }
      ]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "s", "thresholds": { "steps": [{"color":"green","value":null},{"color":"yellow","value":0.5},{"color":"red","value":1}] } },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "title": "Latencia P95 por endpoint",
      "type": "timeseries",
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket{job=\"ades-api\"}[5m]))",
          "legendFormat": "P95 {{handler}}"
        }
      ]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "percentunit" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "id": 3,
      "title": "Tasa de errores 4xx/5xx",
      "type": "timeseries",
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(http_requests_total{job=\"ades-api\",status_code=~\"[45]..\"}[5m]) / rate(http_requests_total{job=\"ades-api\"}[5m])",
          "legendFormat": "Error rate"
        }
      ]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "thresholds" }, "thresholds": { "steps": [{"color":"green","value":null},{"color":"red","value":80}] } }, "overrides": [] },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 8 },
      "id": 4,
      "title": "Requests totales (último minuto)",
      "type": "stat",
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center" },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "increase(http_requests_total{job=\"ades-api\"}[1m])",
          "legendFormat": "Requests/min"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["ades", "api", "fastapi"],
  "time": { "from": "now-3h", "to": "now" },
  "timepicker": {},
  "timezone": "America/Mexico_City",
  "title": "ADES API — Monitoreo",
  "uid": "ades-api-monitor",
  "version": 1
}
