{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "8.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "PostgreSQL Performance — ADES Instituto Nevadi",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "panels": [
    {
      "id": 1,
      "title": "Conexiones Activas",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "targets": [{
        "expr": "pg_stat_activity_count{datname=\"ades\",state=\"active\"}",
        "legendFormat": "Activas"
      }],
      "options": { "colorMode": "background", "graphMode": "area" },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 15 },
            { "color": "red", "value": 25 }
          ]}
        }
      }
    },
    {
      "id": 2,
      "title": "Total Conexiones a PostgreSQL",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "targets": [{
        "expr": "pg_stat_activity_count{datname=\"ades\"}",
        "legendFormat": "Total"
      }],
      "options": { "colorMode": "background" },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 50 },
            { "color": "red", "value": 80 }
          ]}
        }
      }
    },
    {
      "id": 3,
      "title": "Cache Hit Ratio",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "targets": [{
        "expr": "pg_ades_cache_hit_cache_hit_pct",
        "legendFormat": "Cache Hit %"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0, "max": 100,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null },
            { "color": "yellow", "value": 90 },
            { "color": "green", "value": 95 }
          ]}
        }
      }
    },
    {
      "id": 4,
      "title": "Queries Lentas (>5s)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "targets": [{
        "expr": "pg_ades_long_queries_count",
        "legendFormat": "Lentas"
      }],
      "options": { "colorMode": "background" },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 1 },
            { "color": "red", "value": 5 }
          ]}
        }
      }
    },
    {
      "id": 5,
      "title": "Tamaño BD ades",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "targets": [{
        "expr": "pg_database_size_bytes{datname=\"ades\"}",
        "legendFormat": "BD Size"
      }],
      "options": { "colorMode": "value" },
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "id": 6,
      "title": "Estado de Conexiones",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        {
          "expr": "pg_stat_activity_count{datname=\"ades\",state=\"active\"}",
          "legendFormat": "Activas"
        },
        {
          "expr": "pg_stat_activity_count{datname=\"ades\",state=\"idle\"}",
          "legendFormat": "Idle"
        },
        {
          "expr": "pg_stat_activity_count{datname=\"ades\",state=\"idle in transaction\"}",
          "legendFormat": "Idle in TX"
        }
      ],
      "fieldConfig": { "defaults": { "custom": { "lineWidth": 2 } } }
    },
    {
      "id": 7,
      "title": "Top 10 Tablas por Tamaño",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [{
        "expr": "topk(10, pg_ades_table_sizes_size_bytes)",
        "legendFormat": "{{ table_name }}"
      }],
      "options": {
        "orientation": "horizontal",
        "displayMode": "lcd"
      },
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "id": 8,
      "title": "Ratio Índice vs Sequential Scan",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [{
        "expr": "pg_ades_index_usage_index_usage_pct",
        "legendFormat": "{{ tablename }}"
      }],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 } }
    },
    {
      "id": 9,
      "title": "Bloat — Filas Muertas por Tabla",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [{
        "expr": "pg_ades_bloat_estimate_dead_pct > 0",
        "legendFormat": "{{ tablename }}"
      }],
      "options": {
        "orientation": "horizontal",
        "displayMode": "basic"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 10 },
            { "color": "red", "value": 20 }
          ]}
        }
      }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 36,
  "tags": ["postgresql", "ades", "sprint5"],
  "time": { "from": "now-3h", "to": "now" },
  "timepicker": {},
  "timezone": "America/Mexico_City",
  "title": "PostgreSQL Performance — ADES",
  "uid": "ades-postgresql-perf",
  "version": 1
}
