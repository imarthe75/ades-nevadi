{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "8.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "ADES Application Performance — FastAPI + Spring Boot BFF",
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "panels": [
    {
      "id": 1, "title": "Requests/s (FastAPI)",
      "type": "stat", "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "targets": [{ "expr": "sum(rate(http_requests_total{job=\"ades-api\"}[1m]))", "legendFormat": "RPS" }],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 2, "title": "Error Rate 5xx",
      "type": "stat", "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "targets": [{ "expr": "sum(rate(http_requests_total{job=\"ades-api\",status=~\"5..\"}[5m])) / sum(rate(http_requests_total{job=\"ades-api\"}[5m])) * 100", "legendFormat": "Error %" }],
      "fieldConfig": { "defaults": { "unit": "percent",
        "thresholds": { "mode": "absolute", "steps": [
          { "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 5 }
        ]}
      }}
    },
    {
      "id": 3, "title": "P95 Latencia (ms)",
      "type": "stat", "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "targets": [{ "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"ades-api\"}[5m])) by (le)) * 1000", "legendFormat": "P95 ms" }],
      "fieldConfig": { "defaults": { "unit": "ms",
        "thresholds": { "mode": "absolute", "steps": [
          { "color": "green", "value": null }, { "color": "yellow", "value": 500 }, { "color": "red", "value": 2000 }
        ]}
      }}
    },
    {
      "id": 4, "title": "API Up/Down",
      "type": "stat", "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "targets": [{ "expr": "up{job=\"ades-api\"}", "legendFormat": "FastAPI" }],
      "options": { "colorMode": "background" },
      "fieldConfig": { "defaults": { "mappings": [
        { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
      ]}}
    },
    {
      "id": 5, "title": "BFF Up/Down",
      "type": "stat", "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "targets": [{ "expr": "up{job=\"ades-bff\"}", "legendFormat": "Spring BFF" }],
      "options": { "colorMode": "background" },
      "fieldConfig": { "defaults": { "mappings": [
        { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
      ]}}
    },
    {
      "id": 6, "title": "Throughput por Endpoint (Top 10)",
      "type": "timeseries", "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [{ "expr": "topk(10, sum(rate(http_requests_total{job=\"ades-api\"}[5m])) by (handler))", "legendFormat": "{{ handler }}" }],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 7, "title": "Latencia P50 / P95 / P99",
      "type": "timeseries", "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{job=\"ades-api\"}[5m])) by (le)) * 1000", "legendFormat": "P50" },
        { "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"ades-api\"}[5m])) by (le)) * 1000", "legendFormat": "P95" },
        { "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{job=\"ades-api\"}[5m])) by (le)) * 1000", "legendFormat": "P99" }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" } }
    },
    {
      "id": 8, "title": "Distribución Status HTTP",
      "type": "piechart", "gridPos": { "h": 8, "w": 8, "x": 0, "y": 12 },
      "targets": [{ "expr": "sum(rate(http_requests_total{job=\"ades-api\"}[5m])) by (status)", "legendFormat": "{{ status }}" }],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 9, "title": "Requests por Método HTTP",
      "type": "timeseries", "gridPos": { "h": 8, "w": 16, "x": 8, "y": 12 },
      "targets": [{ "expr": "sum(rate(http_requests_total{job=\"ades-api\"}[5m])) by (method)", "legendFormat": "{{ method }}" }],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    }
  ],
  "refresh": "15s",
  "schemaVersion": 36,
  "tags": ["ades", "fastapi", "spring", "application", "sprint5"],
  "time": { "from": "now-3h", "to": "now" },
  "timezone": "America/Mexico_City",
  "title": "ADES Application Performance",
  "uid": "ades-app-perf",
  "version": 1
}
