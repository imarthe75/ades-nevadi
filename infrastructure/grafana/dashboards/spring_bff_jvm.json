{
  "__inputs": [],
  "__requires": [],
  "annotations": { "list": [] },
  "description": "Spring Boot BFF — métricas JVM, HTTP, pool BD. SPRINT 6.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 70 },
            { "color": "red", "value": 90 }
          ] },
          "unit": "percent", "min": 0, "max": 100
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "id": 1,
      "options": { "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "showThresholdLabels": false, "showThresholdMarkers": true },
      "title": "JVM Heap Usage %",
      "type": "gauge",
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "100 * sum(jvm_memory_used_bytes{area=\"heap\", job=\"ades-bff\"}) / sum(jvm_memory_max_bytes{area=\"heap\", job=\"ades-bff\"})",
        "legendFormat": "Heap %",
        "refId": "A"
      }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "bytes", "color": { "mode": "thresholds" },
        "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }
      }, "overrides": [] },
      "gridPos": { "h": 2, "w": 6, "x": 0, "y": 4 },
      "id": 12,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "orientation": "auto", "textMode": "auto", "colorMode": "value" },
      "title": "Heap Máx (jvm_memory_max_bytes)",
      "type": "stat",
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(jvm_memory_max_bytes{area=\"heap\", job=\"ades-bff\"})", "legendFormat": "Heap Máx", "refId": "A" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "bytes", "color": { "mode": "palette-classic" } }, "overrides": [] },
      "gridPos": { "h": 6, "w": 9, "x": 6, "y": 0 },
      "id": 2,
      "options": { "legend": { "calcs": [], "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } },
      "title": "JVM Memory — Heap vs Non-Heap",
      "type": "timeseries",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(jvm_memory_used_bytes{area=\"heap\", job=\"ades-bff\"})", "legendFormat": "Heap Used", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(jvm_memory_used_bytes{area=\"nonheap\", job=\"ades-bff\"})", "legendFormat": "Non-Heap Used", "refId": "B" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(jvm_memory_max_bytes{area=\"heap\", job=\"ades-bff\"})", "legendFormat": "Heap Max", "refId": "C" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "palette-classic" } }, "overrides": [] },
      "gridPos": { "h": 6, "w": 9, "x": 15, "y": 0 },
      "id": 3,
      "options": { "legend": { "calcs": [], "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } },
      "title": "JVM Threads",
      "type": "timeseries",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "jvm_threads_live_threads{job=\"ades-bff\"}", "legendFormat": "Live", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "jvm_threads_daemon_threads{job=\"ades-bff\"}", "legendFormat": "Daemon", "refId": "B" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "jvm_threads_peak_threads{job=\"ades-bff\"}", "legendFormat": "Peak", "refId": "C" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" } }, "overrides": [] },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 6 },
      "id": 4,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "right" }, "tooltip": { "mode": "single" } },
      "title": "HTTP Requests/sec por Status",
      "type": "timeseries",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rate(http_server_requests_seconds_count{job=\"ades-bff\", status=~\"2..\"}[1m])", "legendFormat": "2xx", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rate(http_server_requests_seconds_count{job=\"ades-bff\", status=~\"4..\"}[1m])", "legendFormat": "4xx", "refId": "B" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rate(http_server_requests_seconds_count{job=\"ades-bff\", status=~\"5..\"}[1m])", "legendFormat": "5xx", "refId": "C" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s", "color": { "mode": "palette-classic" } }, "overrides": [] },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 6 },
      "id": 5,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "right" }, "tooltip": { "mode": "single" } },
      "title": "Latencia HTTP p50 / p95 / p99",
      "type": "timeseries",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "histogram_quantile(0.50, rate(http_server_requests_seconds_bucket{job=\"ades-bff\"}[5m]))", "legendFormat": "p50", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "histogram_quantile(0.95, rate(http_server_requests_seconds_bucket{job=\"ades-bff\"}[5m]))", "legendFormat": "p95", "refId": "B" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "histogram_quantile(0.99, rate(http_server_requests_seconds_bucket{job=\"ades-bff\"}[5m]))", "legendFormat": "p99", "refId": "C" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "palette-classic" } }, "overrides": [] },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 13 },
      "id": 6,
      "options": { "legend": { "calcs": ["lastNotNull"], "displayMode": "table", "placement": "right" }, "tooltip": { "mode": "single" } },
      "title": "Conexiones Pool JDBC (HikariCP)",
      "type": "timeseries",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "hikaricp_connections_active{job=\"ades-bff\"}", "legendFormat": "Activas", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "hikaricp_connections_idle{job=\"ades-bff\"}", "legendFormat": "Idle", "refId": "B" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "hikaricp_connections_pending{job=\"ades-bff\"}", "legendFormat": "Pendientes", "refId": "C" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "hikaricp_connections_max{job=\"ades-bff\"}", "legendFormat": "Máximo", "refId": "D" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s", "color": { "mode": "palette-classic" } }, "overrides": [] },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 13 },
      "id": 7,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } },
      "title": "GC Pause Time (ms) — rate 5m",
      "type": "timeseries",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rate(jvm_gc_pause_seconds_sum{job=\"ades-bff\"}[5m]) * 1000", "legendFormat": "{{action}} {{cause}}", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "thresholds" },
        "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] },
        "mappings": []
      }, "overrides": [] },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 20 },
      "id": 8,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "title": "HTTP 5xx en último minuto",
      "type": "stat",
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(increase(http_server_requests_seconds_count{job=\"ades-bff\", status=~\"5..\"}[1m]))", "refId": "A" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s", "color": { "mode": "thresholds" },
        "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.5 }, { "color": "red", "value": 2 }] }
      }, "overrides": [] },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 20 },
      "id": 9,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "orientation": "auto", "textMode": "auto", "colorMode": "value" },
      "title": "Latencia p95 actual",
      "type": "stat",
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "histogram_quantile(0.95, rate(http_server_requests_seconds_bucket{job=\"ades-bff\"}[5m]))", "refId": "A" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "ms", "color": { "mode": "thresholds" },
        "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 3600000 }] }
      }, "overrides": [] },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 20 },
      "id": 10,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "title": "JVM Uptime",
      "type": "stat",
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "process_uptime_seconds{job=\"ades-bff\"} * 1000", "refId": "A" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "reqps", "color": { "mode": "thresholds" },
        "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
      }, "overrides": [] },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 20 },
      "id": 11,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "orientation": "auto", "textMode": "auto", "colorMode": "value" },
      "title": "Requests/sec (total)",
      "type": "stat",
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(rate(http_server_requests_seconds_count{job=\"ades-bff\"}[1m]))", "refId": "A" }]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 37,
  "tags": ["ades", "spring", "jvm", "sprint6"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "America/Mexico_City",
  "title": "Spring BFF — JVM & HTTP",
  "uid": "ades-bff-jvm",
  "version": 2
}
