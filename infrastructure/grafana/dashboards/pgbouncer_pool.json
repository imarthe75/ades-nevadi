{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "8.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "PgBouncer Connection Pool — ADES Instituto Nevadi",
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "panels": [
    {
      "id": 1, "title": "Clientes Activos",
      "type": "stat", "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "targets": [{ "expr": "sum(pgbouncer_pools_cl_active{database=\"ades\"})", "legendFormat": "Activos" }],
      "options": { "colorMode": "background" },
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [
        { "color": "green", "value": null }, { "color": "yellow", "value": 20 }, { "color": "red", "value": 40 }
      ]}}}
    },
    {
      "id": 2, "title": "Clientes Esperando",
      "type": "stat", "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "targets": [{ "expr": "sum(pgbouncer_pools_cl_waiting{database=\"ades\"})", "legendFormat": "Waiting" }],
      "options": { "colorMode": "background" },
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [
        { "color": "green", "value": null }, { "color": "yellow", "value": 5 }, { "color": "red", "value": 10 }
      ]}}}
    },
    {
      "id": 3, "title": "Servidores Activos",
      "type": "stat", "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "targets": [{ "expr": "sum(pgbouncer_pools_sv_active{database=\"ades\"})", "legendFormat": "SV Activos" }],
      "options": { "colorMode": "value" },
      "fieldConfig": { "defaults": {} }
    },
    {
      "id": 4, "title": "Servidores Idle",
      "type": "stat", "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "targets": [{ "expr": "sum(pgbouncer_pools_sv_idle{database=\"ades\"})", "legendFormat": "SV Idle" }],
      "options": { "colorMode": "value" },
      "fieldConfig": { "defaults": {} }
    },
    {
      "id": 5, "title": "Pool Saturation %",
      "type": "gauge", "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "targets": [{ "expr": "100 * sum(pgbouncer_pools_cl_waiting{database=\"ades\"}) / (sum(pgbouncer_pools_cl_active{database=\"ades\"}) + sum(pgbouncer_pools_cl_waiting{database=\"ades\"}) + 1)", "legendFormat": "Saturation" }],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100,
        "thresholds": { "mode": "absolute", "steps": [
          { "color": "green", "value": null }, { "color": "yellow", "value": 50 }, { "color": "red", "value": 80 }
        ]}
      }}
    },
    {
      "id": 6, "title": "Pool de Conexiones — Histórico",
      "type": "timeseries", "gridPos": { "h": 8, "w": 24, "x": 0, "y": 4 },
      "targets": [
        { "expr": "pgbouncer_pools_cl_active{database=\"ades\"}", "legendFormat": "Clientes Activos" },
        { "expr": "pgbouncer_pools_cl_waiting{database=\"ades\"}", "legendFormat": "Esperando" },
        { "expr": "pgbouncer_pools_sv_active{database=\"ades\"}", "legendFormat": "Servidores Activos" },
        { "expr": "pgbouncer_pools_sv_idle{database=\"ades\"}", "legendFormat": "Servidores Idle" }
      ],
      "fieldConfig": { "defaults": { "custom": { "lineWidth": 2 } } }
    },
    {
      "id": 7, "title": "Queries por segundo (PgBouncer)",
      "type": "timeseries", "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [{ "expr": "rate(pgbouncer_stats_queries_total{database=\"ades\"}[1m])", "legendFormat": "QPS" }],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 8, "title": "Latencia promedio cliente (ms)",
      "type": "timeseries", "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [{ "expr": "pgbouncer_stats_avg_query_time{database=\"ades\"} / 1000", "legendFormat": "Avg Query ms" }],
      "fieldConfig": { "defaults": { "unit": "ms",
        "thresholds": { "mode": "absolute", "steps": [
          { "color": "green", "value": null }, { "color": "yellow", "value": 50 }, { "color": "red", "value": 100 }
        ]}
      }}
    }
  ],
  "refresh": "15s",
  "schemaVersion": 36,
  "tags": ["pgbouncer", "pool", "ades", "sprint5"],
  "time": { "from": "now-1h", "to": "now" },
  "timezone": "America/Mexico_City",
  "title": "PgBouncer Connection Pool — ADES",
  "uid": "ades-pgbouncer-pool",
  "version": 1
}
